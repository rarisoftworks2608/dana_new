# ---- Server ----
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ---- MongoDB Atlas ----
# Full connection string from Atlas (Database > Connect > Drivers). Include the
# database name in the path (e.g. .../dana_event?retryWrites=...) so every
# environment (local/Hostinger) talks to the right database.
MONGODB_URI=mongodb+srv://dana_event:dana_event123@dana-cluster.adckuqh.mongodb.net/dana_event?appName=dana-cluster

# ---- JWT ----
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=12h

# ---- Default admin (created by `npm run seed:admin`) ----
DEFAULT_ADMIN_EMAIL=admin@danaevent.com
DEFAULT_ADMIN_PASSWORD=ChangeThisPassword123

# ---- Meta WhatsApp Cloud API ----
# Leave WHATSAPP_SANDBOX_MODE=true until you have real credentials -
# messages will just be logged to the console instead of sent.
WHATSAPP_SANDBOX_MODE=true
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_TEMPLATE_NAME=event_registration_confirmation

# ---- Brevo transactional email API ----
# Sent over HTTPS (not SMTP) - many hosts (e.g. Railway) block outbound SMTP
# ports at the network level. BREVO_API_KEY is the REST API key (Settings >
# SMTP & API > API Keys - starts with xkeysib-, NOT the SMTP key which
# starts with xsmtpsib-). EMAIL_FROM_ADDRESS must be a verified sender in
# Brevo. Leave BREVO_API_KEY empty to sandbox (log only, no real email sent).
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM_ADDRESS=info@eventsportal.in
EMAIL_FROM_NAME=Dana Supplier Technology Day 2026
